---
/**
 * Globo SVG a proiezione ortografica (d3-geo), calcolato a build-time:
 * statico, non spostabile, zoomato sulla porzione Europa + Golfo dove
 * stanno le sedi. Il resto del mondo resta oltre il bordo della sfera
 * (nascosto). Solo pin cliccabili, nessun collegamento. Stile brand:
 * disco navy, terre in silhouette, graticola oro tenue, pin oro.
 */
import { geoOrthographic, geoPath, geoGraticule10, geoDistance } from 'd3-geo';
import { feature } from 'topojson-client';
import land110m from 'world-atlas/land-110m.json';

interface Marker {
  lat: number;
  lng: number;
  city: string;
  role: string;
  country: string;
  primary?: boolean;
}
interface Props {
  markers: Marker[];
  centerLat?: number;
  centerLng?: number;
  /** raggio della sfera in unità viewBox (zoom) */
  radius?: number;
  /** true = pin come bottoni (aprono scheda via JS); altrimenti link a href */
  interactive?: boolean;
  href?: string;
  label?: string;
}
const {
  markers,
  centerLat = 44,
  centerLng = 17,
  radius = 300,
  interactive = false,
  href = '/sedi/',
  label = 'Globo delle sedi',
} = Astro.props;

const SIZE = 640;
const center: [number, number] = [SIZE / 2, SIZE / 2];

const projection = geoOrthographic()
  .rotate([-centerLng, -centerLat])
  .scale(radius)
  .translate(center)
  .clipAngle(90);

const path = geoPath(projection);

// @ts-expect-error — topojson land object
const landGeo = feature(land110m, land110m.objects.land);
const landPath = path(landGeo) ?? '';
const graticulePath = path(geoGraticule10()) ?? '';

const centerCoord: [number, number] = [centerLng, centerLat];

// posizioni proiettate dei pin (solo lato visibile della sfera)
const pins = markers
  .map((m, i) => {
    const p = projection([m.lng, m.lat]);
    const visible = p && geoDistance([m.lng, m.lat], centerCoord) < Math.PI / 2;
    return p && visible ? { ...m, i, x: p[0], y: p[1] } : null;
  })
  .filter((p): p is NonNullable<typeof p> => p !== null);
---

<div class:list={['globe-svg-wrap', { 'is-interactive': interactive }]}>
  <svg viewBox={`0 0 ${SIZE} ${SIZE}`} role="img" aria-label={label} class="globe-svg">
    <defs>
      <radialGradient id="globe-sphere" cx="42%" cy="38%" r="72%">
        <stop offset="0" stop-color="#13284A" />
        <stop offset="1" stop-color="#0A1322" />
      </radialGradient>
    </defs>

    <!-- sfera -->
    <circle cx={center[0]} cy={center[1]} r={radius} fill="url(#globe-sphere)" stroke="var(--gold)" stroke-width="1" stroke-opacity="0.45" />

    <!-- graticola tenue -->
    <path d={graticulePath} fill="none" stroke="var(--gold)" stroke-width="0.6" stroke-opacity="0.2" />

    <!-- terre in silhouette -->
    <path d={landPath} fill="#284C82" fill-opacity="0.95" stroke="var(--gold)" stroke-width="0.5" stroke-opacity="0.4" />

    <!-- pin -->
    <g class="pins">
      {pins.map((p) => (
        <g
          class:list={['pin', { primary: p.primary }]}
          transform={`translate(${p.x} ${p.y})`}
          data-index={String(p.i)}
          data-city={p.city}
          data-country={p.country}
          data-role={p.role}
          role={interactive ? 'button' : undefined}
          tabindex={interactive ? '0' : undefined}
          aria-label={interactive ? `Sede di ${p.city}` : undefined}
        >
          <circle class="pin-halo" r="16" />
          <circle class="pin-dot" r={p.primary ? 6 : 5} />
          <circle class="pin-core" r="2" />
          <text class="pin-label" x="0" y="-16" text-anchor="middle">{p.city}</text>
        </g>
      ))}
    </g>
  </svg>

  {!interactive && <a class="globe-link" href={href} aria-label="Vai alla pagina delle sedi"></a>}
</div>

<style>
  .globe-svg-wrap { position: relative; width: 100%; }
  .globe-svg { width: 100%; height: auto; display: block; overflow: hidden; }
  .globe-link { position: absolute; inset: 0; }

  .pin { }
  .pin-halo { fill: var(--gold); opacity: 0; transition: opacity 0.35s ease; }
  .pin-dot { fill: var(--gold); }
  .pin-core { fill: #0A1322; }
  .pin.primary .pin-dot { fill: var(--gold-soft); }
  .pin-label {
    font-family: var(--sans); font-size: 13px; font-weight: 600;
    fill: #ECE5D6; letter-spacing: 0.02em; opacity: 0; transition: opacity 0.3s ease;
    paint-order: stroke; stroke: #0A1322; stroke-width: 3.5px;
    pointer-events: none;
  }
  .pin:hover .pin-halo, .pin.active .pin-halo { opacity: 0.24; }
  .pin:hover .pin-label, .pin.active .pin-label { opacity: 1; fill: var(--gold-soft); }
  .pin.active .pin-dot { fill: var(--gold-soft); }

  /* pin interattivi (in /sedi) cliccabili */
  .is-interactive .pin { cursor: pointer; }
  .is-interactive .pin:focus-visible { outline: none; }
  .is-interactive .pin:focus-visible .pin-halo { opacity: 0.32; }
</style>
