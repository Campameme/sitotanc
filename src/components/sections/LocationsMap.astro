---
import SectionHead from '../SectionHead.astro';
import { locations } from '../../data/locations';
import { url } from '../../lib/url';

const hq = locations.find((l) => l.primary) ?? locations[0];
---

<section class="presence-map" id="sedi">
  <div class="wrap">
    <SectionHead eyebrow="Le nostre sedi">
      <Fragment slot="title">Sette sedi tra Europa e Golfo</Fragment>
      <p slot="lead">
        Presidiamo i centri industriali e finanziari che contano. Seleziona una
        sede sulla mappa: ci muoviamo verso di lei e apriamo la scheda.
      </p>
    </SectionHead>

    <div class="map-layout" data-reveal>
      <!-- Mappa stilizzata (personalizzata, in stile sito) -->
      <div class="map-wrap">
        <svg class="map-svg" viewBox="0 0 1000 640" role="img" aria-label="Mappa delle sedi tra Europa e Golfo" preserveAspectRatio="xMidYMid meet">
          <defs>
            <radialGradient id="map-bg" cx="42%" cy="38%" r="80%">
              <stop offset="0" stop-color="#12233F" />
              <stop offset="1" stop-color="#0A1322" />
            </radialGradient>
          </defs>
          <rect width="1000" height="640" fill="url(#map-bg)" />

          <!-- graticola tenue -->
          <g class="graticule" stroke="#C2A35B" stroke-width="0.5" opacity="0.12">
            <path d="M0 160 H1000 M0 320 H1000 M0 480 H1000" />
            <path d="M200 0 V640 M400 0 V640 M600 0 V640 M800 0 V640" />
          </g>

          <!-- masse stilizzate: Europa + penisola arabica -->
          <g class="land" fill="#16294A" opacity="0.85">
            <path d="M250 210 q60 -60 150 -55 q80 4 120 45 q40 -15 95 5 q40 15 40 60 q30 20 20 70 q-10 55 -70 70 q-30 60 -110 55 q-70 -4 -110 -50 q-70 10 -110 -35 q-40 -45 -20 -110 q10 -35 5 -70 z" />
            <path d="M660 400 q40 -30 95 -20 q60 12 80 55 q15 45 -20 80 q-45 40 -95 20 q-45 -20 -55 -70 q-8 -40 -5 -65 z" />
          </g>
          <g class="coast" fill="none" stroke="#C2A35B" stroke-width="1" opacity="0.22">
            <path d="M250 210 q60 -60 150 -55 q80 4 120 45 q40 -15 95 5 q40 15 40 60 q30 20 20 70 q-10 55 -70 70 q-30 60 -110 55 q-70 -4 -110 -50 q-70 10 -110 -35 q-40 -45 -20 -110 q10 -35 5 -70 z" />
            <path d="M660 400 q40 -30 95 -20 q60 12 80 55 q15 45 -20 80 q-45 40 -95 20 q-45 -20 -55 -70 q-8 -40 -5 -65 z" />
          </g>

          <!-- gruppo interno: pan/zoom applicato qui -->
          <g data-map-inner style="transform-box: view-box; transform-origin: 0 0; transition: transform 0.8s cubic-bezier(0.4,0,0.2,1);">
            <!-- rotte dall'HQ alle altre sedi -->
            <g class="routes" stroke="#C2A35B" stroke-width="1" fill="none" opacity="0.5">
              {locations.filter((l) => !l.primary).map((l) => (
                <path d={`M${hq.mapX} ${hq.mapY} Q ${(hq.mapX + l.mapX) / 2} ${Math.min(hq.mapY, l.mapY) - 40} ${l.mapX} ${l.mapY}`} stroke-dasharray="2 8" />
              ))}
            </g>

            <!-- marker -->
            {locations.map((l, i) => (
              <g class:list={['marker', { hq: l.primary }]} data-marker={String(i)} data-role={l.role} transform={`translate(${l.mapX} ${l.mapY})`} role="button" tabindex="0" aria-label={`Sede di ${l.city}`}>
                <circle class="m-halo" r="16" />
                <rect class="m-rombo" x="-6" y="-6" width="12" height="12" transform="rotate(45)" />
                <circle class="m-dot" r="3.5" />
                <text class="m-label" x="0" y="-20" text-anchor="middle">{l.city}</text>
              </g>
            ))}
          </g>
        </svg>

        <button class="map-reset" type="button" data-map-reset hidden>Vista d’insieme</button>
      </div>

      <!-- elenco + scheda -->
      <aside class="map-side">
        <ul class="sede-list" data-sede-list>
          {locations.map((l, i) => (
            <li>
              <button type="button" class:list={['sede-item', { primary: l.primary }]} data-item={String(i)}>
                <span class="si-city">{l.city}</span>
                <span class="si-cc">{l.country}</span>
              </button>
            </li>
          ))}
        </ul>

        <div class="sede-card" data-sede-card hidden>
          <span class="sc-eyebrow" data-sc-cc></span>
          <h3 class="sc-city" data-sc-city></h3>
          <p class="sc-role" data-sc-role></p>
          <a href={url('/contatti/')} class="btn btn-solid sc-cta">Contatta questa sede</a>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .presence-map {
    background: var(--panel-2);
    border-top: 1px solid var(--hair-faint);
    border-bottom: 1px solid var(--hair-faint);
  }
  .map-layout {
    display: grid;
    grid-template-columns: 1.55fr 1fr;
    gap: 40px;
    align-items: start;
  }

  .map-wrap {
    position: relative;
    border: 1px solid var(--hair);
    border-radius: var(--radius-card);
    overflow: hidden;
    background: #0A1322;
  }
  .map-svg { width: 100%; height: auto; display: block; }

  .marker { cursor: pointer; }
  .m-halo { fill: var(--gold); opacity: 0; transition: opacity 0.4s ease; }
  .m-rombo { fill: none; stroke: var(--gold); stroke-width: 1.4; transform-box: fill-box; transform-origin: center; }
  .m-dot { fill: var(--gold); }
  .marker.hq .m-rombo { stroke-width: 1.8; }
  .marker.hq .m-dot { r: 4.5; fill: var(--gold-soft); }
  .m-label {
    font-family: var(--sans); font-size: 13px; font-weight: 600;
    fill: #ECE5D6; letter-spacing: 0.02em;
    opacity: 0.85; transition: opacity 0.3s ease;
    paint-order: stroke; stroke: #0A1322; stroke-width: 3px;
  }
  .marker:hover .m-halo, .marker.active .m-halo { opacity: 0.22; }
  .marker:hover .m-label, .marker.active .m-label { opacity: 1; fill: var(--gold-soft); }
  .marker.active .m-dot { fill: var(--gold-soft); }
  .marker:focus-visible { outline: none; }
  .marker:focus-visible .m-halo { opacity: 0.3; }

  .map-reset {
    position: absolute; top: 14px; right: 14px;
    font-family: var(--sans); font-size: 12px; font-weight: 700;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: #ECE5D6;
    background: rgba(10, 19, 34, 0.8);
    border: 1px solid var(--hair);
    border-radius: 20px;
    padding: 8px 16px; cursor: pointer;
    backdrop-filter: blur(6px);
    transition: all 0.25s ease;
  }
  .map-reset[hidden] { display: none; }
  .map-reset:hover { border-color: var(--gold); color: var(--gold-soft); }

  /* elenco */
  .sede-list { list-style: none; border-top: 1px solid var(--hair-faint); }
  .sede-item {
    width: 100%; text-align: left;
    display: flex; flex-direction: column; gap: 4px;
    padding: 16px 14px;
    background: transparent; border: none;
    border-bottom: 1px solid var(--hair-faint);
    cursor: pointer;
    transition: background 0.25s ease, padding 0.25s ease;
  }
  .sede-item:hover { background: var(--panel); padding-left: 20px; }
  .sede-item.active { background: var(--panel); padding-left: 20px; }
  .si-city { font-family: var(--disp); font-size: 21px; font-weight: 700; color: var(--ink); }
  .sede-item.primary .si-city::after {
    content: "◆"; font-size: 9px; color: var(--accent-text);
    vertical-align: super; margin-left: 8px;
  }
  .si-cc {
    font-family: var(--sans); font-size: 11px; font-weight: 600; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--accent-text);
  }

  /* scheda */
  .sede-card {
    margin-top: 26px;
    padding: 26px 28px;
    background: var(--panel);
    border: 1px solid var(--hair);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius-card);
    animation: cardIn 0.4s ease both;
  }
  .sede-card[hidden] { display: none; }
  @keyframes cardIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }
  .sc-eyebrow {
    font-family: var(--sans); font-size: 11px; font-weight: 700; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--accent-text);
  }
  .sc-city { font-family: var(--disp); font-size: 30px; font-weight: 800; color: var(--ink); margin: 8px 0 8px; }
  .sc-role { color: var(--muted); font-size: 17px; line-height: 1.5; }
  .sc-cta { margin-top: 20px; font-size: 12px; padding: 12px 22px; }

  @media (max-width: 900px) {
    .map-layout { grid-template-columns: 1fr; gap: 30px; }
  }
</style>

<script>
  const inner = document.querySelector<SVGGElement>('[data-map-inner]');
  const markers = [...document.querySelectorAll<SVGGElement>('[data-marker]')];
  const items = [...document.querySelectorAll<HTMLButtonElement>('[data-item]')];
  const card = document.querySelector<HTMLElement>('[data-sede-card]');
  const reset = document.querySelector<HTMLButtonElement>('[data-map-reset]');

  // coordinate + dati passati inline dal server
  const data = [
    ...markers.map((m) => {
      const t = m.getAttribute('transform') || '';
      const match = t.match(/translate\(([\d.]+)\s+([\d.]+)\)/);
      return { x: match ? +match[1] : 0, y: match ? +match[2] : 0 };
    }),
  ];

  const VB_W = 1000, VB_H = 640, ZOOM = 2.1;
  const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

  const setActive = (idx: number | null) => {
    markers.forEach((m, i) => m.classList.toggle('active', i === idx));
    items.forEach((it, i) => it.classList.toggle('active', i === idx));
  };

  const select = (idx: number) => {
    const { x, y } = data[idx];
    const tx = VB_W / 2 - ZOOM * x;
    const ty = VB_H / 2 - ZOOM * y;
    if (inner) inner.style.transform = reduced ? 'none' : `translate(${tx}px, ${ty}px) scale(${ZOOM})`;
    setActive(idx);

    const item = items[idx];
    if (card && item) {
      const city = item.querySelector('.si-city')?.textContent ?? '';
      const cc = item.querySelector('.si-cc')?.textContent ?? '';
      const roleEl = card.querySelector<HTMLElement>('[data-sc-role]');
      (card.querySelector('[data-sc-city]') as HTMLElement).textContent = city;
      (card.querySelector('[data-sc-cc]') as HTMLElement).textContent = cc;
      // il ruolo lo prendiamo dall'attributo del marker
      if (roleEl) roleEl.textContent = markers[idx].getAttribute('data-role') ?? '';
      card.hidden = false;
    }
    if (reset) reset.hidden = false;
  };

  const resetView = () => {
    if (inner) inner.style.transform = 'none';
    setActive(null);
    if (card) card.hidden = true;
    if (reset) reset.hidden = true;
  };

  markers.forEach((m, i) => {
    m.addEventListener('click', () => select(i));
    m.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); select(i); }
    });
  });
  items.forEach((it, i) => it.addEventListener('click', () => select(i)));
  reset?.addEventListener('click', resetView);
</script>
