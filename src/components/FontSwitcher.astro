---
/**
 * Anteprima coppie di font — pannello globale (in basso a sinistra)
 * per provare Titoli (primario, sostituisce --disp) + Testo (secondario,
 * sostituisce --body/--sans). Scelta persistita in localStorage e
 * riapplicata su ogni pagina dallo script anti-FOUC in BaseLayout.
 * Strumento di valutazione: da rimuovere al go-live.
 */
const PRIMARY = [
  { key: 'kaisei', label: 'Attuale', preview: '"Kaisei Tokumin", serif' },
  { key: 'playfair', label: 'Playfair SC', preview: '"Playfair Display SC", serif' },
  { key: 'bodoni', label: 'Bodoni Moda', preview: '"Bodoni Moda", serif' },
];
const SECONDARY = [
  { key: 'figtree', label: 'Attuale', preview: '"Figtree", sans-serif' },
  { key: 'libre', label: 'Libre Baskerville', preview: '"Libre Baskerville", serif' },
  { key: 'didact', label: 'Didact Gothic', preview: '"Didact Gothic", sans-serif' },
];
---

<div class="font-switch" data-font-switch>
  <button class="fs-toggle" data-fs-toggle aria-expanded="false" aria-controls="fs-panel">
    <span class="fs-aa">Aa</span> Stile
  </button>
  <div class="fs-panel" id="fs-panel" data-fs-panel hidden>
    <div class="fs-row">
      <span class="fs-label">Tema</span>
      <div class="fs-btns">
        <button class="fs-btn" data-role="theme" data-key="default">Chiaro (blu)</button>
        <button class="fs-btn" data-role="theme" data-key="dark">Scuro (blu+oro)</button>
      </div>
    </div>
    <div class="fs-row">
      <span class="fs-label">Titoli</span>
      <div class="fs-btns">
        {PRIMARY.map((f) => (
          <button class="fs-btn" data-role="primary" data-key={f.key} style={`font-family:${f.preview}`}>{f.label}</button>
        ))}
      </div>
    </div>
    <div class="fs-row">
      <span class="fs-label">Testo</span>
      <div class="fs-btns">
        {SECONDARY.map((f) => (
          <button class="fs-btn" data-role="secondary" data-key={f.key} style={`font-family:${f.preview}`}>{f.label}</button>
        ))}
      </div>
    </div>
    <p class="fs-note">Anteprima — le scelte ti seguono tra le pagine.</p>
  </div>
</div>

<style>
  .font-switch {
    position: fixed; left: 20px; bottom: 20px; z-index: 55;
    font-family: var(--sans);
  }
  .fs-toggle {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 13px; font-weight: 700; letter-spacing: 0.06em;
    color: var(--ink);
    background: var(--panel);
    border: 1px solid var(--hair);
    border-radius: 30px;
    padding: 11px 18px; cursor: pointer;
    box-shadow: 0 8px 24px rgba(6, 27, 61, 0.16);
    transition: all 0.25s ease;
  }
  .fs-toggle:hover { border-color: var(--accent); }
  .fs-aa { font-family: var(--disp); font-size: 17px; font-weight: 700; line-height: 1; }

  .fs-panel {
    position: absolute; left: 0; bottom: calc(100% + 12px);
    width: 300px;
    background: var(--panel);
    border: 1px solid var(--hair);
    border-radius: 12px;
    box-shadow: 0 18px 50px rgba(6, 27, 61, 0.22);
    padding: 18px;
  }
  .fs-panel[hidden] { display: none; }
  .fs-row { margin-bottom: 16px; }
  .fs-label {
    display: block;
    font-size: 10px; font-weight: 700; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--accent-text);
    margin-bottom: 10px;
  }
  .fs-btns { display: flex; flex-wrap: wrap; gap: 8px; }
  .fs-btn {
    font-size: 15px; font-weight: 600;
    color: var(--ink-dim);
    background: var(--bg-2);
    border: 1px solid var(--hair-faint);
    border-radius: 8px;
    padding: 9px 13px; cursor: pointer;
    transition: all 0.2s ease;
  }
  .fs-btn:hover { border-color: var(--accent); color: var(--ink); }
  .fs-btn.active { background: var(--accent); border-color: var(--accent); color: var(--on-accent); }
  .fs-note {
    font-size: 11px; color: var(--muted); margin: 4px 0 0;
    padding-top: 12px; border-top: 1px solid var(--hair-faint);
  }

  @media (max-width: 700px) {
    .font-switch { left: 12px; bottom: 12px; }
    .fs-panel { width: min(300px, calc(100vw - 24px)); }
  }
</style>

<script>
  const P: Record<string, string> = {
    kaisei: '"Kaisei Tokumin", Georgia, serif',
    playfair: '"Playfair Display SC", Georgia, serif',
    bodoni: '"Bodoni Moda", Georgia, serif',
  };
  const S: Record<string, string> = {
    figtree: '"Figtree", system-ui, sans-serif',
    libre: '"Libre Baskerville", Georgia, serif',
    didact: '"Didact Gothic", system-ui, sans-serif',
  };

  const root = document.documentElement;
  const wrap = document.querySelector<HTMLElement>('[data-font-switch]');
  const toggle = document.querySelector<HTMLButtonElement>('[data-fs-toggle]');
  const panel = document.querySelector<HTMLElement>('[data-fs-panel]');

  if (wrap && toggle && panel) {
    const setOpen = (open: boolean) => {
      panel.hidden = !open;
      toggle.setAttribute('aria-expanded', String(open));
    };
    toggle.addEventListener('click', () => setOpen(panel.hidden));
    document.addEventListener('click', (e) => {
      if (!wrap.contains(e.target as Node)) setOpen(false);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setOpen(false);
    });

    // Tema nativo della pagina (non toccato dallo script anti-FOUC), per "Chiaro"
    const pageTheme = root.getAttribute('data-page-theme') || 'light';

    const markActive = () => {
      const p = localStorage.getItem('fr-font-primary') || 'kaisei';
      const s = localStorage.getItem('fr-font-secondary') || 'figtree';
      const t = localStorage.getItem('fr-theme') || 'default';
      panel.querySelectorAll<HTMLButtonElement>('.fs-btn').forEach((b) => {
        const key = b.dataset.key!;
        const role = b.dataset.role!;
        b.classList.toggle(
          'active',
          (role === 'primary' && key === p) ||
            (role === 'secondary' && key === s) ||
            (role === 'theme' && key === t)
        );
      });
    };

    panel.querySelectorAll<HTMLButtonElement>('.fs-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const key = btn.dataset.key!;
        const role = btn.dataset.role!;
        if (role === 'primary') {
          root.style.setProperty('--disp', P[key]);
          localStorage.setItem('fr-font-primary', key);
        } else if (role === 'secondary') {
          root.style.setProperty('--body', S[key]);
          root.style.setProperty('--sans', S[key]);
          localStorage.setItem('fr-font-secondary', key);
        } else if (role === 'theme') {
          // "Scuro" forza il tema scuro ovunque; "Chiaro" ripristina il default di pagina
          root.setAttribute('data-theme', key === 'dark' ? 'dark' : pageTheme);
          localStorage.setItem('fr-theme', key);
        }
        markActive();
      });
    });

    markActive();
  }
</script>
